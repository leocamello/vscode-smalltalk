  - include: '#all_literals'
  - include: '#identifiers_and_variables'
  - include: '#gst_file_out_chunk_separators'
  - include: '#punctuation_general'

repository:
  shebang:
    # Matches lines that start EXACTLY with '#!'.
    # The rest of the line after '#!' is also consumed by this rule.
    # LIMITATION: This pattern currently does NOT support shebang lines
    # with leading whitespace (e.g., ' #!/usr/bin/gst'). This is a known
    # issue to be potentially addressed later if deemed necessary.
    # The current implementation prioritizes a reliably working pattern for the most common case.
    match: '^(#!)(.*)' # Regex: Start of line, capture '#!', capture rest of line.
    captures:
      '0': # The entire match (e.g., '#!/usr/bin/gst -f')
        name: comment.line.shebang.gst.smalltalk
      '1': # The first capture group, which is '(#! )'
        name: punctuation.definition.comment.shebang.gst.smalltalk

  comments:
    # Matches Smalltalk-style double-quoted comments.
    # These comments can span multiple lines.
    name: comment.block.double-quoted.smalltalk # Overall scope for the comment block
    begin: '"'  # Pattern to signify the start of a comment
    end: '"'    # Pattern to signify the end of a comment
    beginCaptures:
      '0': # The opening quote character itself
        name: punctuation.definition.comment.begin.smalltalk
    endCaptures:
      '0': # The closing quote character itself
        name: punctuation.definition.comment.end.smalltalk
    # This pattern correctly handles multi-line comments.
    # It will not conflict with single-quoted string literals, which will be
    # defined with a separate pattern (e.g., in '#literals_string').

