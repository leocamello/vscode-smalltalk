patterns:
  # The order of includes is important. Shebang and comments should generally be matched first.
  - include: '#shebang'
  - include: '#comments'
  - include: '#gst_definition_structures'
  - include: '#gst_other_constructs'
  - include: '#message_sends'
  - include: '#assignments_and_returns' # Added from plan for completeness of structure
