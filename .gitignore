# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# VS Code specific
*.vsix
# TypeScript / esbuild output (inline comments are NOT valid in .gitignore)
out/
dist/

# VS Code Editor specific
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/

# Operating System specific
.DS_Store
Thumbs.db

# Test & Coverage Output
coverage/
*.lcov

# Environment Variables
.env*
!.env.example

# Build Artifacts (if applicable beyond .vsix)
build/

# Other entries
syntaxes/gnu-smalltalk.tmLanguage.json
.vscode-test/

# e2e fixture workspace settings written by VS Code during tests
client/test-e2e/fixtures/.vscode/
