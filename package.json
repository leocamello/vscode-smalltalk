{
    "name": "vscode-smalltalk",
    "displayName": "SmallTalk",
    "description": "SmallTalk Language Support for Visual Studio Code",
    "author": {
        "name": "Leonardo Nascimento",
        "email": "leocamello@gmail.com"
    },
    "publisher": "leocamello",
    "license": "MIT",
    "version": "0.1.1",
    "preview": true,
    "icon": "icon.png",
    "repository": {
        "url": "https://github.com/leocamello/vscode-smalltalk"
    },
    "bugs": {
        "url": "https://github.com/leocamello/vscode-smalltalk/issues"
    },
    "engines": {
        "vscode": "^1.82.0"
    },
    "categories": [
        "Programming Languages",
        "Snippets"
    ],
    "contributes": {
        "languages": [
            {
                "id": "smalltalk",
                "aliases": [
                    "SmallTalk",
                    "smalltalk",
                    "GNU Smalltalk"
                ],
                "extensions": [
                    ".st",
                    ".gst"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "smalltalk",
                "scopeName": "source.smalltalk.gnu",
                "path": "./syntaxes/gnu-smalltalk.tmLanguage.json",
                "unbalancedBracketScopes": [
                    "constant.character.simple.smalltalk",
                    "constant.character.numeric.gst.smalltalk"
                ]
            }
        ],
        "snippets": [
            {
                "language": "smalltalk",
                "path": "./snippets/snippets.json"
            }
        ],
        "configuration": {
            "title": "SmallTalk",
            "properties": {
                "smalltalk.gnuSmalltalkPath": {
                    "type": "string",
                    "default": "",
                    "description": "Absolute path to the GNU Smalltalk executable (gst). If empty, the extension will attempt to find 'gst' in your system PATH."
                }
            }
        }
    },
    "devDependencies": {
        "@vscode/test-cli": "^0.0.10",
        "@vscode/test-electron": "^2.5.2",
        "@vscode/vsce": "^3.3.2",
        "js-yaml": "^4.1.0",
        "vscode-tmgrammar-test": "^0.1.3"
    },
    "scripts": {
        "vscode:prepublish": "npm run build:grammar",
        "test": "vscode-test",
        "deploy": "vsce publish",
        "build:grammar": "js-yaml syntaxes/gnu-smalltalk.YAML-tmLanguage > syntaxes/gnu-smalltalk.tmLanguage.json",
        "test:grammar": "node src/test/grammar-verification.js"
    }
}
