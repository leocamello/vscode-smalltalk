{
	"ifTrue:ifFalse:": {
		"prefix": "if",
		"body": "ifTrue: [ $1 ] ifFalse: [ $2 ]",
		"description": "ifTrue:ifFalse: block",
		"scope": "source.smalltalk.gnu, source.smalltalk"
	},
	"ifTrue:": {
		"prefix": "ift",
		"body": "ifTrue: [ $1 ]",
		"description": "ifTrue: block",
		"scope": "source.smalltalk.gnu, source.smalltalk"
	},
	"ifFalse:": {
		"prefix": "iff",
		"body": "ifFalse: [ $1 ]",
		"description": "ifFalse: block",
		"scope": "source.smalltalk.gnu, source.smalltalk"
	},
	"ifNil:": {
		"prefix": "ifn",
		"body": "ifNil: [ $1 ]",
		"description": "ifNil: block",
		"scope": "source.smalltalk.gnu, source.smalltalk"
	},
	"ifNotNil:": {
		"prefix": "ifnn",
		"body": "ifNotNil: [ :${1:arg} | $2 ]",
		"description": "ifNotNil: block",
		"scope": "source.smalltalk.gnu, source.smalltalk"
	},
	"do:": {
		"prefix": "do",
		"body": "do: [ :${1:each} | $0 ]",
		"description": "do: iteration",
		"scope": "source.smalltalk.gnu, source.smalltalk"
	},
	"collect:": {
		"prefix": "col",
		"body": "collect: [ :${1:each} | $0 ]",
		"description": "collect: mapping",
		"scope": "source.smalltalk.gnu, source.smalltalk"
	},
	"select:": {
		"prefix": "sel",
		"body": "select: [ :${1:each} | $0 ]",
		"description": "select: filtering",
		"scope": "source.smalltalk.gnu, source.smalltalk"
	},
	"reject:": {
		"prefix": "rej",
		"body": "reject: [ :${1:each} | $0 ]",
		"description": "reject: filtering",
		"scope": "source.smalltalk.gnu, source.smalltalk"
	},
	"detect:": {
		"prefix": "det",
		"body": "detect: [ :${1:each} | $0 ]",
		"description": "detect: finding",
		"scope": "source.smalltalk.gnu, source.smalltalk"
	},
	"timesRepeat:": {
		"prefix": "rep",
		"body": "timesRepeat: [ $0 ]",
		"description": "timesRepeat: loop",
		"scope": "source.smalltalk.gnu, source.smalltalk"
	},
	"whileTrue:": {
		"prefix": "wt",
		"body": "whileTrue: [ $1 ]",
		"description": "whileTrue: loop",
		"scope": "source.smalltalk.gnu, source.smalltalk"
	},
	"whileFalse:": {
		"prefix": "wf",
		"body": "whileFalse: [ $1 ]",
		"description": "whileFalse: loop",
		"scope": "source.smalltalk.gnu, source.smalltalk"
	},
	"on:do:": {
		"prefix": "ond",
		"body": "on: ${1:Error} do: [ :${2:ex} | $0 ]",
		"description": "on:do: exception handler",
		"scope": "source.smalltalk.gnu, source.smalltalk"
	},
	"ensure:": {
		"prefix": "ens",
		"body": "ensure: [ $0 ]",
		"description": "ensure: cleanup block",
		"scope": "source.smalltalk.gnu, source.smalltalk"
	},
	"ifCurtailed:": {
		"prefix": "ifc",
		"body": "ifCurtailed: [ $0 ]",
		"description": "ifCurtailed: unwind block",
		"scope": "source.smalltalk.gnu, source.smalltalk"
	},
	"ifNil:ifNotNil:": {
		"prefix": "ifninn",
		"body": "ifNil: [ $1 ] ifNotNil: [ :${2:arg} | $3 ]",
		"description": "ifNil:ifNotNil: block",
		"scope": "source.smalltalk.gnu, source.smalltalk"
	},
	"ifNotNil:ifNil:": {
		"prefix": "ifnnin",
		"body": "ifNotNil: [ :${1:arg} | $2 ] ifNil: [ $3 ]",
		"description": "ifNotNil:ifNil: block",
		"scope": "source.smalltalk.gnu, source.smalltalk"
	},
	"at:ifAbsent:": {
		"prefix": "atia",
		"body": "at: ${1:key} ifAbsent: [ $0 ]",
		"description": "at:ifAbsent: lookup",
		"scope": "source.smalltalk.gnu, source.smalltalk"
	},
	"at:ifAbsentPut:": {
		"prefix": "atiap",
		"body": "at: ${1:key} ifAbsentPut: [ $0 ]",
		"description": "at:ifAbsentPut: memoize",
		"scope": "source.smalltalk.gnu, source.smalltalk"
	},
	"keysAndValuesDo:": {
		"prefix": "kvd",
		"body": "keysAndValuesDo: [ :${1:key} :${2:value} | $0 ]",
		"description": "keysAndValuesDo: iteration",
		"scope": "source.smalltalk.gnu, source.smalltalk"
	},
	"keysDo:": {
		"prefix": "kd",
		"body": "keysDo: [ :${1:key} | $0 ]",
		"description": "keysDo: iteration",
		"scope": "source.smalltalk.gnu, source.smalltalk"
	},
	"inject:into:": {
		"prefix": "inj",
		"body": "inject: ${1:0} into: [ :${2:acc} :${3:each} | $0 ]",
		"description": "inject:into: fold",
		"scope": "source.smalltalk.gnu, source.smalltalk"
	},
	"doWithIndex:": {
		"prefix": "dwi",
		"body": "doWithIndex: [ :${1:each} :${2:index} | $0 ]",
		"description": "doWithIndex: iteration",
		"scope": "source.smalltalk.gnu, source.smalltalk"
	},
	"detect:ifNone:": {
		"prefix": "detin",
		"body": "detect: [ :${1:each} | $2 ] ifNone: [ $0 ]",
		"description": "detect:ifNone: finding",
		"scope": "source.smalltalk.gnu, source.smalltalk"
	},
	"to:do:": {
		"prefix": "to",
		"body": "to: ${1:count} do: [ :${2:i} | $0 ]",
		"description": "to:do: loop",
		"scope": "source.smalltalk.gnu, source.smalltalk"
	},
	"Instance Method": {
		"prefix": "met",
		"body": [
			"${1:message} [",
			"\t<category: '${2:accessing}'>",
			"\t$0",
			"]"
		],
		"description": "Instance method definition",
		"scope": "source.smalltalk.gnu, source.smalltalk"
	},
	"Class Method": {
		"prefix": "cmet",
		"body": [
			"${1:Class} class >> ${2:message} [",
			"\t$0",
			"]"
		],
		"description": "Class method definition",
		"scope": "source.smalltalk.gnu, source.smalltalk"
	},
	"Class Extension": {
		"prefix": "ext",
		"body": [
			"${1:Class} extend [",
			"\t$0",
			"]"
		],
		"description": "Class extension",
		"scope": "source.smalltalk.gnu, source.smalltalk"
	},
	"Namespace": {
		"prefix": "ns",
		"body": [
			"Namespace current: ${1:Name} [",
			"\t$0",
			"]"
		],
		"description": "Namespace definition",
		"scope": "source.smalltalk.gnu, source.smalltalk"
	},
	"Eval": {
		"prefix": "eval",
		"body": [
			"Eval [",
			"\t$0",
			"]"
		],
		"description": "Eval block",
		"scope": "source.smalltalk.gnu, source.smalltalk"
	},
	"Subclass": {
		"prefix": "sub",
		"body": [
			"${1:Object} subclass: ${2:Name} [",
			"\t| ${3:temps} |",
			"\t<category: '${4:category}'>",
			"\t<comment: '${5:comment}'>",
			"\t$0",
			"]"
		],
		"description": "Class definition (subclass)",
		"scope": "source.smalltalk.gnu, source.smalltalk"
	},
    "Block": {
        "prefix": "[",
        "body": "[ $0 ]",
        "description": "Block closure",
        "scope": "source.smalltalk.gnu, source.smalltalk"
    },
    "assert": {
		"prefix": "as",
		"body": "self assert: ${1:expression}",
		"description": "assert",
		"scope": "source.smalltalk.gnu, source.smalltalk"
	},
    "return": {
		"prefix": "ret",
		"body": "^${1:self}",
		"description": "return",
		"scope": "source.smalltalk.gnu, source.smalltalk"
	}
}